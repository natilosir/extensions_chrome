{
  "manifest_version":3,
  "name":"Natilos.ir",
  "version":"1.0",
  "description":"AI",
  "permissions":[
	"activeTab",
	"storage"
  ],
  "host_permissions":[
	"<all_urls>"
  ],
  "action":{
	"default_popup":"xc/popup.html",
	"default_icon":{
	  "16":"xc/icon16.png",
	  "48":"xc/icon48.png",
	  "128":"xc/icon128.png"
	}
  },
  "content_scripts":[
	{
	  "matches":[
		"https://grok.com/*"
	  ],
	  "css":[
		"grok.css"
	  ],
	  "js":[
		"grok.js"
	  ]
	},
	{
	  "matches":[
		"https://chat.deepseek.com/*"
	  ],
	  "js":[
		"deepseek.js"
	  ],
	  "css":[
		"deepseek.css"
	  ]
	},
	{
	  "matches":[
		"https://monica.im/*"
	  ],
	  "js":[
		"monica.js"
	  ],
	  "css":[
		"monica.css"
	  ]
	},
	{
	  "matches":[
		"https://chatgpt.com/*"
	  ],
	  "js":[
		"chatgpt.js"
	  ],
	  "css":[
		"chatgpt.css"
	  ]
	},
	{
	  "matches":[
		"https://chat.qwen.ai/*"
	  ],
	  "css":[
		"qwen.css"
	  ],
	  "js":[
		"qwen.js"
	  ]
	},
	{
	  "matches":[
		"https://food.gau.ac.ir/*"
	  ],
	  "css":[
		"gau.css"
	  ]
	},
	{
	  "matches":[
		"https://www.google.com/search*"
	  ],
	  "css":[
		"google.css"
	  ]
	},
	{
	  "matches":[
		"https://fa.wikipedia.org/*"
	  ],
	  "css":[
		"wikipedia.css"
	  ]
	},
	{
	  "matches":[
		"https://x.com/*"
	  ],
	  "css":[
		"x.css"
	  ]
	},
	{
	  "matches":[
		"https://gapgpt.app/*"
	  ],
	  "css":[
		"gapgpt.css"
	  ]
	},
	{
	  "matches":[
		"https://fa.m.wikipedia.org/*"
	  ],
	  "css":[
		"wikipedia.css"
	  ]
	},
	{
	  "matches":[
		"<all_urls>"
	  ],
	  "css":[
		"all.css"
	  ],
	  "run_at":"document_start"
	}
  ],
  "icons":{
	"16":"xc/icon16.png",
	"48":"xc/icon48.png",
	"128":"xc/icon128.png"
  }
}